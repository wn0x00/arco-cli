{
  "name": "@guanzhu.me/arco-cli",
  "version": "0.1.1",
  "description": "Initialize a project from selectable Arco templates",
  "keywords": [
    "arco",
    "material",
    "init"
  ],
  "bin": {
    "arco": "lib/bin.js"
  },
  "scripts": {
    "init": "yarn install --frozen-lockfile",
    "build": "tsc",
    "dev": "tsc -w",
    "clean": "rm -rf lib",
    "preRelease": "yarn build",
    "prepublishOnly": "npm run build",
    "format": "prettier --config .prettierrc --write \"src/**/*.{js,jsx,ts,tsx}\"",
    "eslint": "eslint src --fix --cache --quiet --ext .js,.jsx,.ts,.tsx"
  },
  "dependencies": {
    "chalk": "^4.0.0",
    "commander": "^4.1.1",
    "fs-extra": "^9.0.1",
    "inquirer": "^7.2.0",
    "ora": "^5.3.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^9.0.11",
    "@types/inquirer": "^7.3.3",
    "@types/jest": "^27.4.1",
    "@types/node": "^15.6.0",
    "@typescript-eslint/eslint-plugin": "^3.10.1",
    "@typescript-eslint/parser": "^3.10.1",
    "eslint": "^6.0.0",
    "eslint-config-airbnb": "^18.1.0",
    "eslint-config-prettier": "^6.5.0",
    "eslint-plugin-babel": "^5.3.0",
    "eslint-plugin-import": "^2.14.0",
    "eslint-plugin-jsx-a11y": "^6.1.2",
    "eslint-plugin-prettier": "^3.1.3",
    "eslint-plugin-react": "^7.12.3",
    "eslint-plugin-typescript": "^0.14.0",
    "husky": "^4.3.0",
    "jest": "^27.0.6",
    "lint-staged": "^10.2.4",
    "prettier": "^2.0.5",
    "ts-jest": "^27.0.3",
    "ts-node": "^10.7.0",
    "typescript": "^4.4.3"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "lib"
  ],
  "license": "MIT",
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "npm run eslint",
      "git add"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  }
}
